#!/usr/bin/env bash
# mythos-tokens — Per-session token accounting from Claude Code transcripts.
#
# Reads ~/.claude/projects/<encoded-cwd>/<session>.jsonl and sums
# message.usage.{input_tokens, output_tokens, cache_creation_input_tokens,
# cache_read_input_tokens}.

set -euo pipefail

cwd="${CLAUDE_PROJECT_DIR:-$PWD}"
# Claude Code encodes paths: every non-[A-Za-z0-9._-] becomes "-" (spaces, slashes, etc.).
enc="$(printf '%s' "$cwd" | sed -E 's/[^A-Za-z0-9._-]/-/g')"
TRANSCRIPT_DIR="${HOME}/.claude/projects/${enc}"

usage() {
  cat <<EOF
mythos-tokens — token accounting from Claude Code transcripts

Usage:
  mythos-tokens session [<session-id|file>]  Tokens for one session (default: latest)
  mythos-tokens all                          Totals across every session in this project
  mythos-tokens list                         List session IDs found
  mythos-tokens --json [sub-cmd] [args]      Emit JSON instead of human format
  mythos-tokens --help                       This help

Transcript dir: $TRANSCRIPT_DIR
EOF
}

JSON_OUT=0
if [ "${1:-}" = "--json" ]; then
  JSON_OUT=1
  shift
fi

ensure_dir() {
  if [ ! -d "$TRANSCRIPT_DIR" ]; then
    echo "no transcripts at $TRANSCRIPT_DIR" >&2
    exit 2
  fi
}

# Sum tokens from one JSONL file. Returns 4 fields tab-separated: in out cache_create cache_read
sum_file() {
  local f="$1"
  if ! command -v jq >/dev/null 2>&1; then
    echo "jq required" >&2; return 3
  fi
  jq -r '
    .message.usage // empty
    | [
        (.input_tokens // 0),
        (.output_tokens // 0),
        (.cache_creation_input_tokens // 0),
        (.cache_read_input_tokens // 0)
      ]
    | @tsv
  ' "$f" 2>/dev/null | awk -F'\t' '
    { i+=$1; o+=$2; cc+=$3; cr+=$4 }
    END { printf "%d\t%d\t%d\t%d\n", i+0, o+0, cc+0, cr+0 }
  '
}

human_row() {
  local label="$1" i="$2" o="$3" cc="$4" cr="$5"
  local total=$(( i + o + cc + cr ))
  printf "%-30s input=%-8d output=%-8d cache_create=%-8d cache_read=%-8d total=%d\n" \
    "$label" "$i" "$o" "$cc" "$cr" "$total"
}

json_row() {
  local label="$1" i="$2" o="$3" cc="$4" cr="$5"
  jq -nc \
    --arg label "$label" \
    --argjson i "$i" --argjson o "$o" --argjson cc "$cc" --argjson cr "$cr" \
    '{label:$label, input:$i, output:$o, cache_create:$cc, cache_read:$cr, total:($i+$o+$cc+$cr)}'
}

cmd_list() {
  ensure_dir
  ls -1t "$TRANSCRIPT_DIR" | grep -E '\.jsonl$' || true
}

cmd_session() {
  ensure_dir
  local target="${1:-}"
  local file=""
  if [ -z "$target" ]; then
    file="$(ls -1t "$TRANSCRIPT_DIR"/*.jsonl 2>/dev/null | head -1 || true)"
  elif [ -f "$target" ]; then
    file="$target"
  elif [ -f "$TRANSCRIPT_DIR/${target}.jsonl" ]; then
    file="$TRANSCRIPT_DIR/${target}.jsonl"
  else
    echo "session not found: $target" >&2; exit 2
  fi
  if [ -z "$file" ]; then
    echo "no sessions in $TRANSCRIPT_DIR" >&2; exit 2
  fi
  local sums
  sums="$(sum_file "$file")"
  local i o cc cr
  IFS=$'\t' read -r i o cc cr <<<"$sums"
  local label
  label="$(basename "$file" .jsonl)"
  if [ "$JSON_OUT" = 1 ]; then
    json_row "$label" "$i" "$o" "$cc" "$cr"
  else
    human_row "$label" "$i" "$o" "$cc" "$cr"
  fi
}

cmd_all() {
  ensure_dir
  local total_i=0 total_o=0 total_cc=0 total_cr=0
  local rows=""
  for f in "$TRANSCRIPT_DIR"/*.jsonl; do
    [ -f "$f" ] || continue
    local sums i o cc cr
    sums="$(sum_file "$f")"
    IFS=$'\t' read -r i o cc cr <<<"$sums"
    local label
    label="$(basename "$f" .jsonl)"
    if [ "$JSON_OUT" = 1 ]; then
      rows="${rows}$(json_row "$label" "$i" "$o" "$cc" "$cr")"$'\n'
    else
      human_row "$label" "$i" "$o" "$cc" "$cr"
    fi
    total_i=$(( total_i + i ))
    total_o=$(( total_o + o ))
    total_cc=$(( total_cc + cc ))
    total_cr=$(( total_cr + cr ))
  done
  if [ "$JSON_OUT" = 1 ]; then
    local rows_arr
    rows_arr="$(printf '%s' "$rows" | jq -s '.')"
    jq -nc \
      --argjson rows "$rows_arr" \
      --argjson ti "$total_i" --argjson to "$total_o" \
      --argjson tcc "$total_cc" --argjson tcr "$total_cr" \
      '{sessions:$rows, totals:{input:$ti, output:$to, cache_create:$tcc, cache_read:$tcr, total:($ti+$to+$tcc+$tcr)}}'
  else
    echo "── totals ──"
    human_row "ALL SESSIONS" "$total_i" "$total_o" "$total_cc" "$total_cr"
  fi
}

case "${1:-session}" in
  session) shift; cmd_session "${1:-}" ;;
  all)     cmd_all ;;
  list)    cmd_list ;;
  -h|--help|help) usage ;;
  *) echo "unknown subcommand: $1" >&2; usage >&2; exit 1 ;;
esac
