#!/usr/bin/env python3
"""
Mythos Observability Dashboard
Aggregates .claude/memory/events.jsonl and eval-metrics.jsonl into a terse text
dashboard. Designed to be cheap to run on demand from /diagnose or PostToolUse.

Usage:
  ./bin/mythos-observe [--events PATH] [--evals PATH] [--json]
"""
import argparse
import json
import os
from collections import Counter, defaultdict
from datetime import datetime


def read_jsonl(path):
    if not os.path.exists(path):
        return []
    rows = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rows.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return rows


def analyze(events, evals):
    out = {
        "events_total": len(events),
        "events_by_type": Counter(),
        "tools_by_use": Counter(),
        "subagents_by_use": Counter(),
        "exit_nonzero": 0,
        "last_event_ts": None,
        "evals_n": len(evals),
        "evals_last": evals[-1] if evals else None,
        "session_count": 0,
    }
    for ev in events:
        out["events_by_type"][ev.get("event") or "unknown"] += 1
        tool = ev.get("tool")
        if tool:
            out["tools_by_use"][tool] += 1
        sub = ev.get("subagent")
        if sub:
            out["subagents_by_use"][sub] += 1
        ec = ev.get("exit_code")
        if isinstance(ec, int) and ec != 0:
            out["exit_nonzero"] += 1
        ts = ev.get("ts")
        if ts and (out["last_event_ts"] is None or ts > out["last_event_ts"]):
            out["last_event_ts"] = ts
    out["session_count"] = out["events_by_type"].get("SessionStart", 0)
    return out


def render(o):
    lines = []
    lines.append("═══ MYTHOS OBSERVABILITY ═══")
    lines.append(f"events.jsonl rows:    {o['events_total']}")
    lines.append(f"eval-metrics.jsonl:   {o['evals_n']}")
    lines.append(f"last event ts:        {o['last_event_ts'] or '—'}")
    lines.append(f"sessions started:     {o['session_count']}")
    lines.append(f"nonzero tool exits:   {o['exit_nonzero']}")
    if o["events_by_type"]:
        lines.append("\nTop events:")
        for k, v in o["events_by_type"].most_common(10):
            lines.append(f"  {k:<28} {v}")
    if o["tools_by_use"]:
        lines.append("\nTop tools:")
        for k, v in o["tools_by_use"].most_common(8):
            lines.append(f"  {k:<28} {v}")
    if o["subagents_by_use"]:
        lines.append("\nTop subagents:")
        for k, v in o["subagents_by_use"].most_common(8):
            lines.append(f"  {k:<28} {v}")
    if o["evals_last"]:
        lines.append("\nLast self-eval:")
        lines.append(f"  {json.dumps(o['evals_last'])}")
    return "\n".join(lines)


def main():
    here = os.path.dirname(os.path.abspath(__file__))
    project = os.path.normpath(os.path.join(here, ".."))
    ap = argparse.ArgumentParser()
    ap.add_argument("--events", default=os.path.join(project, ".claude", "memory", "events.jsonl"))
    ap.add_argument("--evals",  default=os.path.join(project, ".claude", "memory", "eval-metrics.jsonl"))
    ap.add_argument("--json",   action="store_true")
    args = ap.parse_args()

    events = read_jsonl(args.events)
    evals  = read_jsonl(args.evals)
    o = analyze(events, evals)
    if args.json:
        # JSON-safe: Counters → dicts.
        def jsonable(v):
            return dict(v) if isinstance(v, Counter) else v
        out = {k: jsonable(v) for k, v in o.items()}
        print(json.dumps(out, indent=2, default=str))
    else:
        print(render(o))


if __name__ == "__main__":
    main()
