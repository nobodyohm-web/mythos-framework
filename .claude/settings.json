{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[MYTHOS] Pre-Bash — validating command safety'",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[MYTHOS] Pre-Edit — read before write protocol active'",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/PostTrade.sh\" 2>/dev/null || echo \"[MYTHOS] PostEdit validation skipped (no applicable checks)\"'",
            "timeout": 15000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'echo \"[MYTHOS] Routing: $(date +%H:%M:%S) — Checking lessons and patterns\" && LESSONS=$(grep -c \"^### \" \"${CLAUDE_PROJECT_DIR:-.}/tasks/lessons.md\" 2>/dev/null || echo 0) && echo \"[MYTHOS] $LESSONS lessons in memory\"'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/PreMarket.sh\" 2>/dev/null || echo \"[MYTHOS] PreMarket hook not available\"'",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/auto-learn.sh\" 2>/dev/null || echo \"[MYTHOS] Auto-learn hook not available\"'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "sh -c 'bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/EndOfDay.sh\" 2>/dev/null || echo \"[MYTHOS] EndOfDay hook not available\"'",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/verify-completion.sh\" 2>/dev/null || echo \"[MYTHOS] Completion verification skipped\"'",
            "timeout": 15000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "WebFetch(*)",
      "mcp__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MYTHOS_MODE": "enabled"
  }
}
